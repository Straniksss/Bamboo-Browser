{
  "name": "aventra-browser",
  "productName": "Aventra Browser",
  "version": "1.1.24",
  "description": "Aventra Browser - Premium Desktop Browser",
  "main": "dist-electron/main.js",
  "type": "module",
  "author": "",
  "license": "ISC",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'Linting completed (no ESLint rules defined)'",
    "dist": "electron-builder",
    "release": "node scripts/release.js",
    "release:patch": "node scripts/release.js --patch",
    "release:minor": "node scripts/release.js --minor",
    "release:major": "node scripts/release.js --major"
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "electron-store": "^11.0.2",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.20.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/sql.js": "^1.4.11",
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "^42.4.1",
    "sass": "^1.101.0",
    "sql.js": "^1.14.1",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-electron": "^1.0.4",
    "vite-plugin-electron-renderer": "^1.0.0"
  },
  "build": {
    "productName": "Aventra Browser",
    "appId": "tech.aventra.browser",
    "directories": {
      "output": "release-build"
    },
    "files": [
      "dist-client/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "node_modules/sql.js/dist/sql-wasm.wasm",
        "to": "sql-wasm.wasm"
      },
      {
        "from": "node_modules/sql.js/dist/sql-wasm-browser.wasm",
        "to": "sql-wasm-browser.wasm"
      }
    ],
    "win": {
      "target": [
        "dir",
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Aventra Browser",
      "artifactName": "AventraBrowser-Setup-${version}.${ext}",
      "installerIcon": "build/installer.ico",
      "uninstallerIcon": "build/uninstaller.ico",
      "installerHeaderIcon": "build/icon.ico"
    },
    "publish": null
  }
}
