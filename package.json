{
  "name": "bamboo-browser",
  "productName": "Bamboo Browser",
  "version": "1.1.11",
  "description": "Bamboo Browser - Premium Desktop Browser",
  "main": "dist-electron/main.js",
  "type": "module",
  "author": "",
  "license": "ISC",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "dist": "electron-builder",
    "release": "node scripts/release.js"
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "electron-store": "^11.0.2",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.20.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0",
    "zustand": "^5.0.14"
  },
  "build": {
    "productName": "Bamboo Browser",
    "appId": "tech.bamboo.browser",
    "directories": {
      "output": "release-build"
    },
    "files": [
      "dist-client/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "dir",
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Bamboo Browser",
      "artifactName": "BambooBrowser-Setup-${version}.${ext}",
      "installerIcon": "build/installer.ico",
      "uninstallerIcon": "build/uninstaller.ico",
      "installerHeaderIcon": "build/icon.ico"
    },
    "publish": null
  }
}
